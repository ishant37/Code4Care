# Hospital Infection Surveillance System (HISS) - Environment Configuration
# Copy this file to .env and modify values as needed

# ==================== Server Configuration ====================
# API server host and port
HOST=0.0.0.0
PORT=8000

# Debug mode (set to True for development)
DEBUG=False

# ==================== Data Generation ====================
# Interval in seconds between data generation batches
DATA_GENERATION_INTERVAL=60

# Number of lab tests to generate per batch
BATCH_SIZE=20

# ==================== Anomaly Detection ====================
# Interval in seconds between anomaly detection runs
ANOMALY_CHECK_INTERVAL=30

# Expected proportion of outliers (0.0-0.5)
# Lower values = stricter anomaly detection
ANOMALY_CONTAMINATION=0.1

# Score thresholds for status classification
CRITICAL_THRESHOLD=0.6
WARNING_THRESHOLD=0.35

# ==================== Frontend Integration ====================
# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000

# ==================== Database (Future Enhancement) ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/hiss_db

# ==================== Logging ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== Monitoring & Metrics ====================
# Prometheus metrics endpoint (optional)
METRICS_ENABLED=False
METRICS_PORT=9090
